# cdp-local-dev generated — safe to edit.
# Regenerate keys by deleting this file and running `cdp-dev install`.

AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3

# UID the Airflow containers run as.  On Linux this must equal `id -u`
# so bind-mounted ./logs and ./dags are writable without root.
AIRFLOW_UID=__AIRFLOW_UID__

# Fernet key for encrypting connection passwords in the Airflow metadata DB.
AIRFLOW_FERNET_KEY=__AIRFLOW_FERNET_KEY__

# Flask session signing key for the webserver.
AIRFLOW_WEBSERVER_SECRET_KEY=__AIRFLOW_WEBSERVER_SECRET_KEY__

# Optional — extra pip packages installed into the Airflow containers on start.
# Example: _PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-google==10.17.0
_PIP_ADDITIONAL_REQUIREMENTS=
